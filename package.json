{
  "name": "dev-hub",
  "version": "1.0.0",
  "description": "Development dashboard hub",
  "main": "main.js",
  "author": "StormGamesStudios",
  "license": "ISC",
  "type": "commonjs",

  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux"
  },

  "build": {
    "appId": "com.stormgamesstudios.devhub",
    "productName": "DevHub",

    "files": [
      "**/*"
    ],

    "extraMetadata": {
      "main": "main.js"
    },

    "icon": "icon.png",

    "publish": [
      {
        "provider": "github",
        "owner": "acierto-incomodo",
        "repo": "dev-hub"
      }
    ],

    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "icon.png"
    },

    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "include": "installer.nsh",
      "differentialPackage": true
    },

    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development",
      "icon": "icon.png"
    }
  },

  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1"
  },

  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}